# ──────────────────────────────────────────
# BeamAuth — Environment Variables
# Copy this to .env.local and fill in values
# ──────────────────────────────────────────

# Stellar Network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract IDs (fill in after Phase 2 deployment)
NEXT_PUBLIC_ESCROW_CONTRACT_ID=CAH7SZBIBQPH7E57UOU5MFR6V2VQBROBTMVPJ2MOUCRP7H7NSRIFRDCV
NEXT_PUBLIC_FACTORY_CONTRACT_ID=CCDV672F6FHX4G7FUV7Z4CJNPVAMR445QO6BR2BDKS44YBQET6UJFAX3
NEXT_PUBLIC_PASSKEY_WALLET_WASM_HASH=fd13e7137de16838fb5527bb031231be19b4f37464b55cc655111f4cf45ed8a5

# Stellar Native Asset (XLM) — official Soroban native token contract
# Same ID on testnet and mainnet Soroban deployments
NEXT_PUBLIC_NATIVE_ASSET_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJGWGNRLRHGBHSIM5CXJZYA4VUBOPETB2

# Relayer keypair — NEVER expose this publicly
# Generate on Stellar Lab: https://laboratory.stellar.org/#account-creator?network=test
RELAYER_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RELAYER_PUBLIC_KEY=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# WebAuthn RP (Relying Party) config
NEXT_PUBLIC_WEBAUTHN_RP_ID=localhost
NEXT_PUBLIC_WEBAUTHN_RP_NAME=BeamAuth
NEXT_PUBLIC_WEBAUTHN_ORIGIN=http://localhost:3000
